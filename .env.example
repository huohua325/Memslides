# MemSlides local runtime environment template.
# Copy to .env only when you need local overrides. Do not commit real values.
# Model endpoints and API keys belong in src/memslides/memslides.yaml placeholders,
# a private YAML file, Web Studio Service Profiles, or shell/CI secrets.

# Local data and workspace roots
MEMSLIDES_DATA_ROOT=.memslides
MEMSLIDES_WORKSPACE_BASE=.memslides/web
MEMSLIDES_DEFAULT_CACHE_ROOT=.memslides

# Optional local private config paths for CLI/conda runs
# MEMSLIDES_CONFIG_FILE=src/memslides/memslides.private.yaml
# MEMSLIDES_MCP_CONFIG_FILE=src/memslides/mcp.private.json

# Optional Playwright/Chromium overrides
# MEMSLIDES_CHROMIUM_EXECUTABLE=.playwright-browsers/chromium-1223/chrome-win64/chrome.exe
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=.playwright-browsers/chromium-1223/chrome-win64/chrome.exe
MEMSLIDES_PLAYWRIGHT_AUTO_INSTALL=0

# Optional PPTX export runtime overrides
# MEMSLIDES_PPTX_EXPORT_NODE_MODULES=node_modules
MEMSLIDES_PPTX_EXPORT_AUTO_INSTALL=0
MEMSLIDES_PPTX_EXPORT_VISUAL_MODE=auto
